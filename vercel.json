{
  "rewrites": [
    {
      "source": "/images/:path*",
      "destination": "https://interapophyseal-bobbie-nondiscriminatory.ngrok-free.dev/images/:path*"
    },
    {
      "source": "/_next/static/media/:path*",
      "destination": "https://interapophyseal-bobbie-nondiscriminatory.ngrok-free.dev/_next/static/media/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "url"
        }
      ],
      "destination": "https://interapophyseal-bobbie-nondiscriminatory.ngrok-free.dev/:path*"
    }
  ],
  "headers": [
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

